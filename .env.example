# Copy to .env.development, .env.test, or .env.production and fill in values.
# Push to Vault: ./cmd/apply-env.ps1

# ── Core ──────────────────────────────────────────────────────────────────────
ENV=

# ── Container Registry ────────────────────────────────────────────────────────
REGISTRY_URL=

# ── Elasticsearch (cmd + release telemetry) ─────────────────────────────────
ELASTIC_URL_PUBLIC=
ELASTIC_URL=
ELASTIC_USER=
ELASTIC_PASSWORD=

# ── Defect Dojo (cmd + release finding steps) ─────────────────────────────────
DEFECT_DOJO_URL_PUBLIC=
DEFECT_DOJO_URL=
DEFECT_DOJO_API_TOKEN=
DEFECT_DOJO_ENGAGEMENT_ID=

# ── SonarQube ───────────────────────────────────────────────────────
SONAR_URL=
SONAR_TOKEN=

# ── Hashicorp Vault ───────────────────────────────────────────────────────────────
VAULT_URL_PUBLIC=
VAULT_URL=
VAULT_TOKEN=

# ── Kibana (cmd) ──────────────────────────────────────────────────────────────
KIBANA_URL_PUBLIC=
KIBANA_USER=
KIBANA_PASSWORD=

# ── Grafana (cmd) ─────────────────────────────────────────────────────────────
GRAFANA_URL_PUBLIC=
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# ── PostHog (cmd + src) ────────────────────────────────────────
POSTHOG_URL_PUBLIC=
POSTHOG_URL=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# ── Sentry (src) ──────────────────────────────────────────────────────────────
SENTRY_URL_PUBLIC=
SENTRY_URL=
SENTRY_AUTH_TOKEN=
SENTRY_PROJECT_ID=

# ── DNS (cmd) ─────────────────────────────────────────────────────────────────
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# ── GitLab (cmd) ──────────────────────────────────────────────────────────────
GITLAB_URL_PUBLIC=
GITLAB_TOKEN=

# ── Database (cmd + src) ────────────────────────────────────────────────────────────
DB_URL_PUBLIC=
DB_URL=

# ── OpenTelemetry (src) ───────────────────────────────────────────────────────
OTEL_URL=
OTEL_HEADERS=
