# Copy to .env.development, .env.test, or .env.production and fill in values.
# Push to Vault: ./cmd/apply-env.ps1

# ── Core ──────────────────────────────────────────────────────────────────────
ENV=

# ── Registry (release) ────────────────────────────────────────────────────────
REGISTRY_URL=

# ── Elasticsearch (cmd + release telemetry) ─────────────────────────────────
ES_URL=
ELASTIC_USER=
ELASTIC_PASSWORD=

# ── Defect Dojo (release finding steps) ───────────────────────────────────────
DEFECT_DOJO_URL=
DEFECT_DOJO_API_TOKEN=
DEFECT_DOJO_ENGAGEMENT_ID=

# ── SonarQube (release) ───────────────────────────────────────────────────────
SONAR_HOST_URL=
SONAR_TOKEN=

# ── Vault (cmd) ───────────────────────────────────────────────────────────────
VAULT_ADDR=
VAULT_TOKEN=
VAULT_READ_TOKEN=

# ── Kibana (cmd) ──────────────────────────────────────────────────────────────
KIBANA_URL=

# ── Grafana (cmd) ─────────────────────────────────────────────────────────────
GRAFANA_URL=
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# ── PostHog (cmd, optional dashboards) ────────────────────────────────────────
POSTHOG_HOST=
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# ── Database (cmd) ────────────────────────────────────────────────────────────
DB_URL=

# ── DNS (cmd) ─────────────────────────────────────────────────────────────────
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=

# ── GitLab (cmd) ──────────────────────────────────────────────────────────────
GITLAB_URL=
GITLAB_TOKEN=

# ── CI (set by runner; documented for local parity) ───────────────────────────
# CI_PROJECT_DIR=
# CI_COMMIT_BRANCH=
# CI_COMMIT_SHA=
# GITHUB_REF_NAME=
# GITHUB_SHA=
